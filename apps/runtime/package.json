{
  "name": "@mcpops/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "pnpm --workspace-root config:validate",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mcpops/db": "workspace:*",
    "@mcpops/runtime-sdk": "workspace:*",
    "@mcpops/sandbox": "workspace:*",
    "@mcpops/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "ajv": "^8.17.1",
    "fastify": "^5.2.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "ioredis": "^5.4.2",
    "jose": "^6.0.11",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": { "@types/pg": "^8.15.5", "tsx": "^4.19.2", "vitest": "^2.1.8" }
}

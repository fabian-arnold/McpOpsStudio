{
  "name": "@mcpops/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "pnpm --workspace-root config:validate",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@mcpops/db": "workspace:*",
    "@mcpops/shared": "workspace:*",
    "@mcpops/sandbox": "workspace:*",
    "argon2": "^0.41.1",
    "ajv": "^8.17.1",
    "bullmq": "^5.34.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": { "@types/node": "^22.10.2", "tsx": "^4.19.2", "vitest": "^2.1.8" }
}

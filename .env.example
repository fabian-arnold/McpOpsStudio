# Development-only defaults. Replace every secret before exposing the stack.
NODE_ENV=development
# Activates the development-only mock CRM Compose profile. Remove both settings
# in non-demo environments and provide real reviewed service integrations.
COMPOSE_PROFILES=demo
MCP_OPS_DEMO_MODE=true
MOCK_CRM_URL=http://mock-crm:8090
POSTGRES_DB=mcp_ops_studio
# Bootstrap credentials are used only by PostgreSQL initialization and must
# differ from the application role below.
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres_dev_password
POSTGRES_USER=mcpops
POSTGRES_PASSWORD=mcpops_dev_password
DATABASE_URL=postgresql://mcpops:mcpops_dev_password@postgres:5432/mcp_ops_studio?schema=public
REDIS_URL=redis://redis:6379

# Exactly 32 bytes as 64 hex characters or base64. This example is development-only.
MCP_OPS_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SESSION_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters

PUBLIC_CONTROL_PLANE_URL=http://localhost:8080
PUBLIC_RUNTIME_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://127.0.0.1:3001
RUNTIME_INTERNAL_URL=http://worker:8080
INTERNAL_API_TOKEN=dev-internal-token-change-me
RUNTIME_CONCURRENCY=40
DEPLOYMENT_CONCURRENCY=2

# Development seed values (documented in README; rotate for any shared environment).
SEED_ADMIN_EMAIL=admin@acme.test
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_MCP_API_KEY=dev-acme-mcp-key
SEED_PRODUCTION_MCP_API_KEY=prod-acme-mcp-key
PRODUCTION_RUNTIME_PUBLIC_URL=http://prod.localhost:8080

EXECUTOR_PROVIDER=local
# Production hostile-code deployments can select the disposable container
# provider. The image must be pre-pulled; executions never pull packages/images.
# CONTAINER_EXECUTOR_IMAGE=registry.example.com/mcpops/executor:1
# CONTAINER_EXECUTOR_RUNTIME=runsc
# CONTAINER_EXECUTOR_MEMORY_MB=256
# CONTAINER_EXECUTOR_CPUS=0.5
# CONTAINER_EXECUTOR_PIDS=64
# Implemented runtime validators; keep disabled until real issuer, audience and
# JWKS-backed policies have been configured and tested for the deployment.
ENABLE_JWT_AUTH=false
ENABLE_ENTRA_AUTH=false
# Enables only administrator-reviewed, fixed PostgreSQL SELECT definitions.
# Arbitrary SQL and connection URLs are never exposed to function code.
ENABLE_REVIEWED_DB_QUERIES=false

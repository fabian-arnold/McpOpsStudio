{
  "name": "mcp-ops-studio",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "turbo build",
    "config:validate": "node scripts/validate-production-config.mjs",
    "config:test": "node --test scripts/validate-production-config.test.mjs scripts/generate-install-config.test.mjs",
    "install:smoke": "node scripts/install-smoke.mjs",
    "dev": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml up --build --watch",
    "dev:local": "pnpm db:generate && pnpm --filter \"./packages/*\" build && turbo dev --parallel",
    "dev:down": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml down --remove-orphans",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "test:e2e": "node scripts/e2e.mjs",
    "db:generate": "pnpm --filter @mcpops/db generate",
    "db:migrate": "pnpm --filter @mcpops/db migrate",
    "db:seed": "pnpm --filter @mcpops/db seed",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check": "node scripts/check-docs.mjs",
    "docs:media": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-doc-demos.ps1"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "vitepress": "1.6.4"
  }
}

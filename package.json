{
  "name": "mcp-ops-studio",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "turbo build",
    "config:validate": "node scripts/validate-production-config.mjs",
    "config:test": "node --test scripts/validate-production-config.test.mjs scripts/generate-install-config.test.mjs scripts/check-workspace-boundaries.test.mjs",
    "install:smoke": "node scripts/install-smoke.mjs",
    "dev": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml up --build --watch",
    "dev:local": "pnpm db:generate && pnpm --filter \"./packages/*\" build && turbo dev --parallel",
    "dev:down": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml down --remove-orphans",
    "lint": "eslint . --max-warnings=51",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:check": "node scripts/check-staged-format.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "analyze": "pnpm analyze:architecture && pnpm analyze:workspace && pnpm analyze:dead-code",
    "analyze:architecture": "depcruise apps packages --config dependency-cruiser.config.cjs",
    "analyze:workspace": "node scripts/check-workspace-boundaries.mjs",
    "analyze:dead-code": "knip --include files,dependencies,unlisted,unresolved",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "test:e2e": "node scripts/e2e.mjs",
    "db:generate": "pnpm --filter @mcpops/db generate",
    "db:migrate": "pnpm --filter @mcpops/db migrate",
    "db:seed": "pnpm --filter @mcpops/db seed",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check": "node scripts/check-docs.mjs",
    "docs:media": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-doc-demos.ps1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@prisma/client": "^6.19.3",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "15.5.20",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "knip": "^6.26.0",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitepress": "1.6.4"
  }
}

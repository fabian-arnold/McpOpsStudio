# Pin an exact GitHub release tag. Do not use latest in retained environments.
MCP_OPS_VERSION=v0.1.0

# The bundled gateway listens on loopback so a host TLS proxy can publish it.
MCP_OPS_BIND_ADDRESS=127.0.0.1
MCP_OPS_PORT=8080
PUBLIC_CONTROL_PLANE_URL=https://mcpops.example.com
PUBLIC_RUNTIME_URL=https://mcpops.example.com

POSTGRES_DB=mcp_ops_studio
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=
POSTGRES_USER=mcpops
# Use a URL-safe value because this password is interpolated into DATABASE_URL.
POSTGRES_PASSWORD=

# Generate independent values with: openssl rand -hex 32
MCP_OPS_MASTER_KEY=
SESSION_SECRET=
CSRF_SECRET=
INTERNAL_API_TOKEN=

# Initial installation-wide administrator and endpoint credentials.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
SEED_MCP_API_KEY=
SEED_PRODUCTION_MCP_API_KEY=

EXECUTOR_PROVIDER=local
RUNTIME_CONCURRENCY=40
DEPLOYMENT_CONCURRENCY=2
LOG_LEVEL=info
ENABLE_JWT_AUTH=false
ENABLE_ENTRA_AUTH=false
ENABLE_REVIEWED_DB_QUERIES=false

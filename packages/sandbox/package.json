{
  "name": "@mcpops/sandbox",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && vitest run --testTimeout=15000"
  },
  "dependencies": {
    "@mcpops/platform-modules": "workspace:*",
    "@mcpops/runtime-sdk": "workspace:*",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "vitest": "^2.1.9"
  }
}
